@using Microsoft.AspNetCore.Identity
@using SmartLogistics.Models
@inject UserManager<AppUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var userInitial = user?.FullName?.Substring(0, 1).ToUpper() ?? "K";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kế Toán Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <style>body { font-family: 'Inter', sans-serif; }</style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dashboard-body">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-wallet2"></i>
            <span>Bộ Phận Kế Toán</span>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-label">Nghiệp vụ</div>
            <a class="nav-link @(currentController == "Accounting" ? "active" : "")"
               asp-controller="Accounting" asp-action="Index">
                <i class="bi bi-bar-chart-line-fill"></i> Báo cáo & Thống kê
            </a>
        </nav>

        <div class="sidebar-user">
            <div class="user-avatar" style="background:var(--sl-accent);">@userInitial</div>
            <div class="user-info">
                <div class="user-name">@user?.FullName</div>
                <div class="user-role">Kế toán</div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-sm btn-outline-light border-0" title="Đăng xuất">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Top Header -->
        <header class="top-header">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    @if (ViewData["Breadcrumb"] is List<(string Text, string Url)> breadcrumbs)
                    {
                        foreach (var item in breadcrumbs)
                        {
                            if (string.IsNullOrEmpty(item.Url))
                            {
                                <li class="breadcrumb-item active">@item.Text</li>
                            }
                            else
                            {
                                <li class="breadcrumb-item"><a href="@item.Url">@item.Text</a></li>
                            }
                        }
                    }
                    else
                    {
                        <li class="breadcrumb-item active">Báo cáo & Thống kê</li>
                    }
                </ol>
            </nav>
            <div class="header-actions">
                <button class="btn-notification" title="Thông báo">
                    <i class="bi bi-bell"></i>
                </button>
                <a asp-controller="Account" asp-action="Profile" class="text-decoration-none text-muted small fw-bold text-nowrap">
                    @user?.FullName <i class="bi bi-person-circle ms-1"></i>
                </a>
            </div>
        </header>

        <!-- Content Area -->
        <div class="content-area">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-custom alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-custom alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
