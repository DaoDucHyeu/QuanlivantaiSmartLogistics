<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartLogistics</title>
    <meta name="description" content="Hệ thống quản lý vận chuyển thông minh SmartLogistics - Theo dõi GPS, quản lý đơn hàng và tối ưu lộ trình" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartLogistics.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        :root {
            --sl-primary: #2563eb;
            --sl-primary-dark: #1d4ed8;
            --sl-secondary: #0f172a;
            --sl-accent: #06b6d4;
            --sl-success: #22c55e;
            --sl-bg-light: #f8fafc;
        }

        * { font-family: 'Inter', -apple-system, sans-serif; }

        /* ===== NAVBAR ===== */
        .sl-navbar {
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding: 0 0;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1050;
            transition: all 0.3s ease;
        }
        .sl-navbar.scrolled {
            background: rgba(15, 23, 42, 0.98);
            box-shadow: 0 4px 30px rgba(0,0,0,0.15);
        }
        .sl-navbar .navbar-brand {
            font-weight: 800;
            font-size: 1.3rem;
            color: #fff !important;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .sl-navbar .navbar-brand .brand-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, var(--sl-primary), var(--sl-accent));
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: #fff;
        }
        .sl-navbar .nav-link {
            color: rgba(255,255,255,0.7) !important;
            font-size: 0.9rem;
            font-weight: 500;
            padding: 8px 16px !important;
            border-radius: 8px;
            transition: all 0.2s ease;
        }
        .sl-navbar .nav-link:hover {
            color: #fff !important;
            background: rgba(255,255,255,0.08);
        }
        .btn-nav-login {
            background: transparent;
            border: 1.5px solid rgba(255,255,255,0.25);
            color: #fff !important;
            padding: 7px 20px !important;
            border-radius: 10px !important;
            font-weight: 600 !important;
            font-size: 0.85rem !important;
            transition: all 0.2s ease;
        }
        .btn-nav-login:hover { border-color: var(--sl-primary); background: var(--sl-primary); }
        .btn-nav-cta {
            background: linear-gradient(135deg, var(--sl-primary), var(--sl-accent));
            color: #fff !important;
            padding: 7px 22px !important;
            border-radius: 10px !important;
            font-weight: 600 !important;
            font-size: 0.85rem !important;
            border: none;
            transition: all 0.2s ease;
        }
        .btn-nav-cta:hover { transform: translateY(-1px); box-shadow: 0 4px 15px rgba(37,99,235,0.4); }

        /* ===== FOOTER ===== */
        .sl-footer {
            background: var(--sl-secondary);
            color: rgba(255,255,255,0.6);
            padding: 48px 0 24px;
        }
        .sl-footer h6 { color: #fff; font-weight: 700; margin-bottom: 16px; font-size: 0.95rem; }
        .sl-footer a { color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.85rem; transition: color 0.2s; }
        .sl-footer a:hover { color: var(--sl-accent); }
        .sl-footer .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.08);
            padding-top: 20px;
            margin-top: 32px;
            font-size: 0.8rem;
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sl-navbar" id="mainNav">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon"><i class="bi bi-truck"></i></span>
                SmartLogistics
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    style="border-color: rgba(255,255,255,0.2);">
                <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto ms-4">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="#features">Tính năng</a></li>
                    <li class="nav-item"><a class="nav-link" href="#stats">Thống kê</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Liên hệ</a></li>
                </ul>
                <ul class="navbar-nav gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var UserManager = Context.RequestServices.GetRequiredService<Microsoft.AspNetCore.Identity.UserManager<AppUser>>();
                        var appUser = await UserManager.GetUserAsync(User);

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false" style="color:#fff !important;">
                                <i class="bi bi-person-circle me-1"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (appUser != null)
                                {
                                    if (appUser.UserType == UserType.Admin)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-grid me-2"></i>Tổng quan</a></li>
                                        <li><a class="dropdown-item" asp-controller="Staff" asp-action="Index"><i class="bi bi-people me-2"></i>Quản lý nhân sự</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    else if (appUser.UserType == UserType.DieuHanh)
                                    {
                                        <li><a class="dropdown-item" asp-controller="OrderManagement" asp-action="Index"><i class="bi bi-box-seam me-2"></i>Quản lý đơn hàng</a></li>
                                        <li><a class="dropdown-item" asp-controller="TripManagement" asp-action="Index"><i class="bi bi-map me-2"></i>Quản lý chuyến đi</a></li>
                                        <li><a class="dropdown-item" asp-controller="VehicleManagement" asp-action="Index"><i class="bi bi-truck me-2"></i>Quản lý phương tiện</a></li>
                                        <li><a class="dropdown-item" asp-controller="Tracking" asp-action="Index"><i class="bi bi-geo-alt me-2"></i>Theo dõi GPS</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    else if (appUser.UserType == UserType.KeToan)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Accounting" asp-action="Index"><i class="bi bi-graph-up me-2"></i>Báo cáo thống kê</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    else if (appUser.UserType == UserType.TaiXe)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Driver" asp-action="Index"><i class="bi bi-truck me-2"></i>Chuyến đi của tôi</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                }
                                
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link btn-nav-login" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="nav-link btn-nav-cta" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus-fill me-1"></i> Đăng ký Branch
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Content -->
    <main style="padding-top: 72px;">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="sl-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="brand-icon" style="width:32px;height:32px;background:linear-gradient(135deg,var(--sl-primary),var(--sl-accent));border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;">
                            <i class="bi bi-truck"></i>
                        </span>
                        <strong style="color:#fff; font-size: 1.1rem;">SmartLogistics</strong>
                    </div>
                    <p style="font-size: 0.85rem; line-height: 1.7; max-width: 300px;">
                        Hệ thống quản lý vận chuyển thông minh, giúp tối ưu lộ trình, theo dõi GPS real-time và quản lý đội xe hiệu quả.
                    </p>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6>Sản phẩm</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li><a href="#features">Tính năng</a></li>
                        <li><a href="#stats">Thống kê</a></li>
                        <li><a href="#">Bảng giá</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6>Hỗ trợ</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        <li><a href="#">Tài liệu</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">Chính sách</a></li>
                        <li><a href="#">FAQ</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h6>Liên hệ</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2" style="font-size: 0.85rem;">
                        <li><i class="bi bi-geo-alt me-2"></i>Đại học Giao thông Vận tải, Hà Nội</li>
                        <li><i class="bi bi-envelope me-2"></i>contact&#64;smartlogistics.vn</li>
                        <li><i class="bi bi-telephone me-2"></i>+84 (0) 24 1234 5678</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom text-center">
                &copy; 2026 SmartLogistics - Đồ án tốt nghiệp. Developed with <i class="bi bi-heart-fill text-danger"></i> by UTC Student.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            document.getElementById('mainNav')?.classList.toggle('scrolled', window.scrollY > 50);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
