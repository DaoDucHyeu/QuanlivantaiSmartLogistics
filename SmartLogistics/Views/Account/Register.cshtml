@model SmartLogistics.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
}

<style>
    .register-wrapper {
        min-height: calc(100vh - 150px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
    }
    .register-card {
        width: 100%;
        max-width: 480px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.08);
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .register-header {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        padding: 32px 32px 28px;
        text-align: center;
    }
    .register-header .register-icon {
        width: 56px; height: 56px;
        background: linear-gradient(135deg, #2563eb, #06b6d4);
        border-radius: 16px;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 1.5rem; color: #fff;
        margin-bottom: 14px;
    }
    .register-header h3 {
        color: #fff; font-weight: 800; font-size: 1.3rem; margin: 0 0 4px;
    }
    .register-header p {
        color: rgba(255,255,255,0.5); font-size: 0.82rem; margin: 0;
    }
    .register-body { padding: 28px 32px 32px; }
    .register-body .form-label {
        font-weight: 600; font-size: 0.85rem; color: #334155;
    }
    .register-body .form-control {
        border-radius: 12px; padding: 11px 14px;
        border: 1.5px solid #e2e8f0; font-size: 0.9rem;
        transition: border-color 0.2s;
    }
    .register-body .form-control:focus {
        border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
    }
    .btn-register {
        width: 100%;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; border: none;
        padding: 12px; border-radius: 12px;
        font-weight: 700; font-size: 0.95rem;
        transition: all 0.2s;
    }
    .btn-register:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(37,99,235,0.35);
        color: #fff;
    }
    .register-footer {
        text-align: center; padding: 16px 32px 24px;
        border-top: 1px solid #f1f5f9;
    }
    .register-footer p {
        color: #94a3b8; font-size: 0.85rem; margin: 0;
    }
    .register-footer i { color: #2563eb; }
</style>

<div class="register-wrapper">
    <div class="register-card">
        <div class="register-header">
            <div class="register-icon"><i class="bi bi-person-plus-fill"></i></div>
            <h3>Đăng ký tài khoản Admin</h3>
            <p>Khởi tạo doanh nghiệp vận tải của riêng bạn</p>
        </div>
        <div class="register-body">
            <form asp-action="Register" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:0.85rem;"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border: 1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
                            <i class="bi bi-card-text" style="color:#64748b;"></i>
                        </span>
                        <input asp-for="FullName" class="form-control" style="border-radius:0 12px 12px 0;" placeholder="Nhập họ và tên" autofocus />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border: 1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
                            <i class="bi bi-person" style="color:#64748b;"></i>
                        </span>
                        <input asp-for="UserName" class="form-control" style="border-radius:0 12px 12px 0;" placeholder="Tên đăng nhập viết liền không dấu" />
                    </div>
                    <span asp-validation-for="UserName" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email (Dùng để xác thực)</label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border: 1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
                            <i class="bi bi-envelope" style="color:#64748b;"></i>
                        </span>
                        <input asp-for="Email" class="form-control" style="border-radius:0 12px 12px 0;" placeholder="Ví dụ: email@domain.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border: 1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
                            <i class="bi bi-lock" style="color:#64748b;"></i>
                        </span>
                        <input asp-for="Password" class="form-control" style="border-radius:0 12px 12px 0;" placeholder="Nhập mật khẩu" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border: 1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
                            <i class="bi bi-shield-check" style="color:#64748b;"></i>
                        </span>
                        <input asp-for="ConfirmPassword" class="form-control" style="border-radius:0 12px 12px 0;" placeholder="Nhập lại mật khẩu" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <button type="submit" class="btn btn-register">
                    <i class="bi bi-check2-circle me-2"></i>Hoàn tất đăng ký
                </button>
            </form>
        </div>
        <div class="register-footer">
            <p>Đã có tài khoản? <a asp-action="Login" class="text-primary text-decoration-none fw-bold">Đăng nhập ngay</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
