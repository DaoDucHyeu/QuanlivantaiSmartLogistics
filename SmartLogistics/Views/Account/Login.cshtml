@model SmartLogistics.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    .login-wrapper {
        min-height: calc(100vh - 150px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
    }
    .login-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.08);
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .login-header {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        padding: 32px 32px 28px;
        text-align: center;
    }
    .login-header .login-icon {
        width: 56px; height: 56px;
        background: linear-gradient(135deg, #2563eb, #06b6d4);
        border-radius: 16px;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 1.5rem; color: #fff;
        margin-bottom: 14px;
    }
    .login-header h3 {
        color: #fff; font-weight: 800; font-size: 1.3rem; margin: 0 0 4px;
    }
    .login-header p {
        color: rgba(255,255,255,0.5); font-size: 0.82rem; margin: 0;
    }
    .login-body { padding: 28px 32px 32px; }
    .login-body .form-label {
        font-weight: 600; font-size: 0.85rem; color: #334155;
    }
    .login-body .form-control {
        border-radius: 12px; padding: 11px 14px;
        border: 1.5px solid #e2e8f0; font-size: 0.9rem;
        transition: border-color 0.2s;
    }
    .login-body .form-control:focus {
        border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
    }
    .btn-login {
        width: 100%;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; border: none;
        padding: 12px; border-radius: 12px;
        font-weight: 700; font-size: 0.95rem;
        transition: all 0.2s;
    }
    .btn-login:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(37,99,235,0.35);
        color: #fff;
    }
    .login-footer {
        text-align: center; padding: 16px 32px 24px;
        border-top: 1px solid #f1f5f9;
    }
    .login-footer p {
        color: #94a3b8; font-size: 0.8rem; margin: 0;
    }
    .login-footer i { color: #2563eb; }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <div class="login-icon"><i class="bi bi-shield-lock-fill"></i></div>
            <h3>Đăng nhập hệ thống</h3>
            <p>SmartLogistics - Quản lý vận tải thông minh</p>
        </div>
        <div class="login-body">
            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="@ViewData["ReturnUrl"]" />
                <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:0.85rem;"></div>

                <div class="mb-3">
                    <label asp-for="UserNameOrEmail" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border: 1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
                            <i class="bi bi-person" style="color:#64748b;"></i>
                        </span>
                        <input asp-for="UserNameOrEmail" class="form-control" style="border-radius:0 12px 12px 0;" placeholder="Nhập tên đăng nhập hoặc email" autofocus />
                    </div>
                    <span asp-validation-for="UserNameOrEmail" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border: 1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
                            <i class="bi bi-lock" style="color:#64748b;"></i>
                        </span>
                        <input asp-for="Password" class="form-control" style="border-radius:0 12px 12px 0;" placeholder="Nhập mật khẩu" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div class="form-check mb-0">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label" style="font-size:0.85rem; color:#64748b;"></label>
                    </div>
                    <a asp-action="ForgotPassword" class="text-primary text-decoration-none fw-semibold" style="font-size: 0.85rem;">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn btn-login">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                </button>
            </form>
        </div>
        <div class="login-footer">
            <p><i class="bi bi-info-circle me-1"></i> Tài khoản Staff được cấp bởi Quản trị viên</p>
            <p class="mt-2 mb-0" style="font-size: 0.85rem">Doanh nghiệp mới? <a asp-action="Register" class="text-primary text-decoration-none fw-bold">Đăng ký tài khoản Admin</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
