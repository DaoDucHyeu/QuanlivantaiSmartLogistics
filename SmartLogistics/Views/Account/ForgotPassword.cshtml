@model SmartLogistics.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
}

<style>
    .login-wrapper {
        min-height: calc(100vh - 150px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
    }
    .login-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.08);
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .login-header {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        padding: 32px 32px 28px;
        text-align: center;
    }
    .login-header .login-icon {
        width: 56px; height: 56px;
        background: linear-gradient(135deg, #ef4444, #f97316);
        border-radius: 16px;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 1.5rem; color: #fff;
        margin-bottom: 14px;
    }
    .login-header h3 {
        color: #fff; font-weight: 800; font-size: 1.3rem; margin: 0 0 4px;
    }
    .login-header p {
        color: rgba(255,255,255,0.7); font-size: 0.85rem; margin: 0;
    }
    .login-body { padding: 28px 32px 32px; }
    .login-body .form-control {
        border-radius: 12px; padding: 11px 14px;
        border: 1.5px solid #e2e8f0; font-size: 0.9rem;
    }
    .login-body .form-control:focus {
        border-color: #f97316; box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
    }
    .btn-submit {
        width: 100%;
        background: linear-gradient(135deg, #ef4444, #f97316);
        color: #fff; border: none;
        padding: 12px; border-radius: 12px;
        font-weight: 700; font-size: 0.95rem;
    }
    .btn-submit:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(239, 68, 68, 0.35);
        color: #fff;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <div class="login-icon"><i class="bi bi-key-fill"></i></div>
            <h3>Khôi phục mật khẩu</h3>
            <p>Nhập email tài khoản của bạn để nhận link đặt lại mật khẩu mới.</p>
        </div>
        <div class="login-body">
            <form asp-action="ForgotPassword" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:0.85rem;"></div>

                <div class="mb-4">
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:12px 0 0 12px; border: 1.5px solid #e2e8f0; border-right:none; background:#f8fafc;">
                            <i class="bi bi-envelope" style="color:#64748b;"></i>
                        </span>
                        <input asp-for="Email" class="form-control" style="border-radius:0 12px 12px 0;" placeholder="Nhập địa chỉ Email" autofocus />
                    </div>
                    <span asp-validation-for="Email" class="text-danger" style="font-size:0.8rem;"></span>
                </div>

                <button type="submit" class="btn btn-submit mb-3">
                    <i class="bi bi-send-fill me-2"></i>Gửi link khôi phục
                </button>
                <div class="text-center">
                    <a asp-action="Login" class="text-decoration-none text-muted" style="font-size: 0.85rem;">
                        <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
