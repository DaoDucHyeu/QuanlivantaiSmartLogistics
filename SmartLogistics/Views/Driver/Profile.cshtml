@using SmartLogistics.Models
@model AppUser

@{
    ViewData["Title"] = "Tài khoản";
    Layout = "_DriverLayout";
    var vehicle = ViewData["Vehicle"] as Vehicle;
}

<style>
    .profile-header {
        background: linear-gradient(135deg, #1e40af, #3b82f6);
        border-radius: 16px;
        padding: 30px 20px;
        color: white;
        text-align: center;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        margin-bottom: 25px;
    }
    .profile-avatar {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background-color: white;
        color: #1e40af;
        font-size: 2.5rem;
        font-weight: bold;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 4px solid rgba(255, 255, 255, 0.3);
        margin-bottom: 15px;
    }
    .info-card {
        border-radius: 16px;
        border: none;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        margin-bottom: 20px;
        overflow: hidden;
    }
    .info-item {
        display: flex;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid #f1f5f9;
    }
    .info-item:last-child {
        border-bottom: none;
    }
    .info-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background-color: #eff6ff;
        color: #3b82f6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-right: 15px;
    }
    .info-content h6 {
        margin: 0;
        font-size: 0.85rem;
        color: #64748b;
    }
    .info-content p {
        margin: 0;
        font-weight: 500;
        color: #1e293b;
        font-size: 1rem;
    }
    .btn-logout {
        border-radius: 12px;
        font-weight: 600;
        padding: 14px;
        background-color: #ef4444;
        border: none;
        box-shadow: 0 4px 6px -1px rgba(239, 68, 68, 0.2);
    }
    .btn-logout:hover {
        background-color: #dc2626;
    }
</style>

<div class="container mt-3 pb-5">
    <!-- Header Section -->
    <div class="profile-header">
        <div class="profile-avatar">
            @(Model.FullName?.Substring(0, 1).ToUpper() ?? "T")
        </div>
        <h4 class="fw-bold mb-1">@Model.FullName</h4>
        <p class="mb-0 opacity-75">Tài xế nội bộ</p>
    </div>

    <!-- Personal Info Section -->
    <h6 class="fw-bold mb-3 text-secondary ps-2">Thông tin liên hệ</h6>
    <div class="card info-card">
        <div class="info-item">
            <div class="info-icon">
                <i class="bi bi-envelope-fill"></i>
            </div>
            <div class="info-content">
                <h6>Email</h6>
                <p>@(string.IsNullOrEmpty(Model.Email) ? "Chưa cập nhật" : Model.Email)</p>
            </div>
        </div>
        <div class="info-item">
            <div class="info-icon">
                <i class="bi bi-telephone-fill"></i>
            </div>
            <div class="info-content">
                <h6>Số điện thoại</h6>
                <p>@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)</p>
            </div>
        </div>
    </div>

    <!-- Job Info Section -->
    <h6 class="fw-bold mb-3 text-secondary ps-2">Thông tin công việc</h6>
    <div class="card info-card">
        <div class="info-item">
            <div class="info-icon" style="background-color: #f0fdf4; color: #22c55e;">
                <i class="bi bi-truck"></i>
            </div>
            <div class="info-content w-100 d-flex justify-content-between align-items-center">
                <div>
                    <h6>Phương tiện hiện tại</h6>
                    <p>@(vehicle != null ? vehicle.BienSo : "Chưa gán xe")</p>
                </div>
                @if (vehicle != null)
                {
                    <span class="badge bg-success bg-opacity-25 text-success rounded-pill px-3 py-2">Sẵn sàng</span>
                }
            </div>
        </div>
        <div class="info-item">
            <div class="info-icon" style="background-color: #fef3c7; color: #f59e0b;">
                <i class="bi bi-person-badge"></i>
            </div>
            <div class="info-content">
                <h6>Vai trò</h6>
                <p>Tài xế</p>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="d-grid mt-4">
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="btn btn-danger w-100 btn-logout">
                <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
            </button>
        </form>
    </div>
</div>
