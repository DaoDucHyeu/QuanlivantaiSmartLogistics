@model SmartLogistics.Helpers.PaginatedList<SmartLogistics.Models.Trip>
@using SmartLogistics.Models
@{
    ViewData["Title"] = "Quản lý Chuyến đi";
    Layout = "~/Views/Shared/_LayoutDieuHanh.cshtml";
}

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body">
                <div class="stat-info">
                    <p>Chưa bắt đầu</p>
                    <h3>@ViewBag.NotStarted</h3>
                </div>
                <div class="stat-icon" style="background: rgba(100,116,139,0.12); color: #64748b;"><i class="bi bi-hourglass-split"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body">
                <div class="stat-info">
                    <p>Đang thực hiện</p>
                    <h3>@ViewBag.InProgress</h3>
                </div>
                <div class="stat-icon bg-primary-light"><i class="bi bi-play-circle-fill"></i></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body">
                <div class="stat-info">
                    <p>Hoàn thành</p>
                    <h3>@ViewBag.Completed</h3>
                </div>
                <div class="stat-icon bg-success-light"><i class="bi bi-check-circle-fill"></i></div>
            </div>
        </div>
    </div>
</div>

<div class="page-title">
    <h2><i class="bi bi-signpost-2-fill me-2"></i>Quản lý Chuyến đi</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-lg me-1"></i> Tạo chuyến đi
    </a>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <form asp-action="Index" method="get" class="d-flex align-items-center gap-2 flex-wrap w-100">
        <input type="text" name="search" class="form-control" style="max-width: 280px;"
               placeholder="Tìm kiếm theo tài xế, biển số..." value="@ViewBag.Search" />
        <select name="status" class="form-select" style="max-width: 190px;">
            <option value="">-- Trạng thái --</option>
            <option value="@TripStatus.ChuaBatDau" selected="@(ViewBag.Status == TripStatus.ChuaBatDau)">Chưa bắt đầu</option>
            <option value="@TripStatus.DangThucHien" selected="@(ViewBag.Status == TripStatus.DangThucHien)">Đang thực hiện</option>
            <option value="@TripStatus.HoanThanh" selected="@(ViewBag.Status == TripStatus.HoanThanh)">Hoàn thành</option>
        </select>
        <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i> Tìm kiếm</button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string) || ViewBag.Status != null)
        {
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg me-1"></i> Xóa lọc</a>
        }
    </form>
</div>

<!-- Data Table -->
<div class="card data-card">
    <div class="table-responsive">
        <table class="table table-dashboard">
            <thead>
                <tr>
                    <th>Mã chuyến</th>
                    <th>Xe</th>
                    <th>Tài xế</th>
                    <th>Thời gian BĐ</th>
                    <th>Thời gian KT</th>
                    <th>Số đơn</th>

                    <th>Trạng thái</th>
                    <th style="width: 140px;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>Không tìm thấy chuyến đi nào
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var trip in Model)
                    {
                        var (badgeClass, statusName) = trip.TrangThai switch
                        {
                            TripStatus.DangThucHien => ("bg-primary", "Đang thực hiện"),
                            TripStatus.HoanThanh => ("bg-success", "Hoàn thành"),
                            TripStatus.Huy => ("bg-danger", "Hủy"),
                            _ => ("bg-secondary", "Chưa bắt đầu")
                        };
                        <tr>
                            <td><strong>#CD@(trip.MaChuyenDi.ToString("D3"))</strong></td>
                            <td>@(trip.Xe?.BienSo ?? "—")</td>
                            <td>@(trip.TaiXe?.FullName ?? "—")</td>
                            <td>@trip.ThoiGianBatDau.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(trip.ThoiGianKetThuc?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                            <td><span class="badge bg-info rounded-pill">@trip.TripDetails.Count</span></td>

                            <td><span class="badge @badgeClass rounded-pill">@statusName</span></td>
                            <td>
                                <a asp-action="Details" asp-route-id="@trip.MaChuyenDi" class="btn-action btn-action-view" title="Xem chi tiết">
                                    <i class="bi bi-eye-fill"></i>
                                </a>
                                @if (trip.TrangThai == TripStatus.ChuaBatDau)
                                {
                                    <form asp-action="Delete" asp-route-id="@trip.MaChuyenDi" method="post" class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa chuyến đi #CD@(trip.MaChuyenDi.ToString("D3"))?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-action btn-action-delete" title="Xóa">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="pagination-info">
        @await Html.PartialAsync("_Pagination", (object)Model)
    </div>
</div>


